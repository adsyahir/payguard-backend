# Shared backend config template. Copy to .env and fill real values.
#   cp .env.example .env

# Postgres container (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Server
USER_SERVICE_PORT=8081

# Database
USER_DB_URL=jdbc:postgresql://localhost:5433/payguard_user
USER_DB_USER=postgres
USER_DB_PASS=postgres

# JPA / Flyway
JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true

# Spring Cloud
CONFIG_SERVER_URI=http://localhost:8888
EUREKA_URI=http://localhost:8761/eureka/

# JWT (min 32 chars for HS256)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_ISSUER=payguard-user
JWT_TTL_SECONDS=3600
